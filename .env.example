# OpsDesk AI — Environment Variables
# Copy to .env and fill in values before running

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=your-very-long-random-secret-key-change-in-production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://opsdesk:opsdesk_secret@localhost:5432/opsdesk

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ML Models ────────────────────────────────────────────────────────────────
MODELS_DIR=../ml/models
DATA_DIR=../data/processed

# ── OpenAI (optional — chatbot degrades gracefully without it) ───────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]

# ── SLA Hours (defaults) ─────────────────────────────────────────────────────
SLA_CRITICAL_HOURS=2
SLA_HIGH_HOURS=8
SLA_MEDIUM_HOURS=24
SLA_LOW_HOURS=72

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
